<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:fillViewport="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/parentSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/img"
        tools:context=".Presentation.FragmentSettings">

        <ImageView
            android:id="@+id/im_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="@+id/tv_settings"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_settings" />

        <TextView
            android:id="@+id/tv_settings"
            style="@style/StyleMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal|center_vertical"
            android:padding="10dp"
            android:text="Общие настройки"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_settings">

            <TextView
                android:id="@+id/bSetTheme"
                style="@style/StyleItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="@drawable/button_background_item_category"
                android:padding="8dp"
                android:text="Тема" />

            <TextView
                android:id="@+id/bSize"
                style="@style/StyleItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="@drawable/button_background_item_category"
                android:padding="8dp"
                android:text="Размер шрифта" />

            <TextView
                android:id="@+id/bSetSort"
                style="@style/StyleItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="@drawable/button_background_item_category"
                android:padding="8dp"
                android:text="Сортировка" />

            <TextView
                android:id="@+id/bAlarm"
                style="@style/StyleItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="@drawable/button_background_item_category"
                android:padding="8dp"
                android:text="Звук будильника" />

            <TextView
                android:id="@+id/bFaq"
                style="@style/StyleItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="@drawable/button_background_item_category"
                android:padding="8dp"
                android:text="Инструкция" />

            <TextView
                android:id="@+id/bCallbackCard"
                style="@style/StyleItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="@drawable/button_background_item_category"
                android:padding="8dp"
                android:text="Обратная связь" />





            <TextView
                android:id="@+id/bDonateCard"
                style="@style/StyleItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="@drawable/button_background_item_category"
                android:padding="8dp"
                android:text="Поддержать разработчика" />

            <TextView
                android:id="@+id/tv_settings_permissions"
                style="@style/StyleMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal|center_vertical"
                android:padding="10dp"
                android:text="Разрешения"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/bBatareiOptimozation"
                style="@style/StyleItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="@drawable/button_background_item_category"
                android:padding="8dp"
                android:text="Работа в фоне" />

            <TextView
                android:id="@+id/bAppSettings"
                style="@style/StyleItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="@drawable/button_background_item_category"
                android:padding="8dp"
                android:text="Настройки приложения" />

            <TextView
                android:id="@+id/tv_settings_backup"
                style="@style/StyleMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal|center_vertical"
                android:padding="10dp"
                android:text="Резервное копирование"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <TextView
                android:id="@+id/saveDb"
                style="@style/StyleItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="@drawable/button_background_item_category"
                android:padding="8dp"
                android:text="Сохранить базу данных" />

            <TextView
                android:id="@+id/loadDb"
                style="@style/StyleItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="@drawable/button_background_item_category"
                android:padding="8dp"
                android:text="Загрузить базу данных" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>


